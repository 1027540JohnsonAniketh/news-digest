# Copy this file to .env and fill in your API keys

# ── Always required ────────────────────────────────────────────────────────────

# Get from: https://console.anthropic.com  (pay-as-you-go, very cheap)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Free news APIs (sign up to get keys) ──────────────────────────────────────

# Get from: https://currentsapi.services  (free — 600 req/day, real-time)
CURRENTS_API_KEY=your_currents_api_key_here

# Get from: https://open-platform.theguardian.com/access  (free, unlimited)
GUARDIAN_API_KEY=your_guardian_api_key_here

# Get from: https://newsdata.io  (free — 200 req/day, real-time + sentiment)
NEWSDATA_API_KEY=your_newsdata_api_key_here

# ── AI-powered live web search (optional but powerful) ────────────────────────

# Get from: https://docs.perplexity.ai  (small free credit on signup)
# Uses the "sonar" model — browses the live web for you
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Get from: https://aistudio.google.com/apikey  (free — 1500 req/day!)
# Uses Gemini 2.0 Flash with Google Search grounding
GEMINI_API_KEY=your_gemini_api_key_here

# ── No key needed (always active) ─────────────────────────────────────────────
# Reddit API    — free, no key
# BBC News RSS  — free, no key
# AP News RSS   — free, no key
# Hacker News   — free, no key
